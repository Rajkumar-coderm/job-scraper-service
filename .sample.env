APP_NAME=Job Scraper API

# Local only — on Render/cloud, headless is forced automatically
DEBUG=false
HEADLESS=false

SCRAPE_ON_STARTUP=false
SCRAPE_SEQUENTIAL=false
ENRICH_HR_LIMIT=5

# Optional — required for Indeed on cloud/datacenter IPs (Render, AWS, etc.)
# Use a residential proxy provider, e.g.:
# PROXY_SERVER=http://username:password@proxy-host:port

# --- Render (auto-detected via RENDER=true) ---
# HEADLESS=true
# SCRAPE_SEQUENTIAL=true
# SCRAPE_ON_STARTUP=false
