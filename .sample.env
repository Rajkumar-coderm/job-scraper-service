APP_NAME=Job Scraper API

# Local: true shows browser windows. Render/production: must be false
DEBUG=false
HEADLESS=false

# Do not scrape on server boot — API calls trigger scrapes
SCRAPE_ON_STARTUP=false

# Run scrapers one-by-one (recommended on Render to save RAM)
SCRAPE_SEQUENTIAL=false

# Max Naukri jobs to fetch HR contacts for when enrich_details=true
ENRICH_HR_LIMIT=5
